# QueryGate environment — copy to `.env` and adjust. `.env` is gitignored; never commit secrets.
#
# Two-URL split (this is the heart of Layer 3 — least privilege):
#   * DATABASE_URL is the ADMIN/migration role. It owns the tables and is used by the
#     seed loader (scripts/seed.py) and the one-time role/grant setup. It can write.
#   * QUERYGATE_DATABASE_URL is the read-only APPLICATION role the server connects as.
#     It has SELECT only — no INSERT/UPDATE/DELETE/CREATE. Every query the agent runs
#     goes through THIS connection, so even a bug in the app cannot reach a write.
# The whole boundary story rests on the server only ever using QUERYGATE_DATABASE_URL.

# --- Admin / migration role (full privileges; used by seed + setup, NOT by the server) ---
DATABASE_URL=postgresql://querygate_admin:admin_pw@localhost:5432/querygate

# --- Read-only application role (SELECT only; used by the server) ---
QUERYGATE_DATABASE_URL=postgresql://querygate:querygate_pw@localhost:5432/querygate

# --- POSTGRES_* consumed by docker-compose to initialise the cluster ---
POSTGRES_USER=querygate_admin
POSTGRES_PASSWORD=admin_pw
POSTGRES_DB=querygate
# Password handed to the read-only role created by scripts/init_role.sql.
QUERYGATE_DB_PASSWORD=querygate_pw

# --- Azure OpenAI (GPT-5.5) — used by the agent/eval in LATER splits, not by Split 01 ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=
CHAT_LLM_MODEL=
